generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

enum VoteType {
  implicit
  explicit
}

enum PostStatus {
  under_review
  upcoming
  backlog
  planned
  in_progress
  complete
  shipped
}

enum UserRole {
  customer
  member
  admin
  owner
}

enum BoardVisibility {
  public
  private
  custom
}

enum PainEventSource {
  freshdesk
  zoom
  slack
}

enum PainEventStatus {
  pending_ai
  needs_triage
  auto_merged
  skipped
  dismissed
  spam
}

enum AiActionTaken {
  auto_upvote
  suggested_new
}

enum AiActionStatus {
  approved
  pending_review
  revoked
}

enum AccessRequestStatus {
  pending
  approved
  rejected
}

enum NotificationType {
  status_change
  comment_reply
  mention
  access_approved
  announcement
}

enum AiInboxRoutingMode {
  central
  individual
}

enum AiTriageMode {
  auto
  manual
}

// ============================================
// TENANT (Company) - The root of multi-tenancy
// ============================================
model Company {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique @default("")  // URL-safe identifier (e.g., "acme-corp")
  monthlySpend     Float    @default(0)
  healthStatus     String   @default("unknown")
  stripeCustomerId String?  @unique
  cannyCompanyId   String?  @unique  // For Canny migration mapping
  
  // Tenant-owned resources
  users            User[]
  boards           Board[]
  aiInboxConfigs   AiInboxConfig[]
  customDomains    CustomDomain[]
  portalSettings   PortalSettings?
  apiCredentials   ApiCredential[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
}

model User {
  id                   String                  @id @default(cuid())
  companyId            String                  @default("")
  email                String
  name                 String                  @default("")
  passwordHash         String?                 // null for OAuth/SSO users
  appUserId            String?
  cannyUserId          String?                 // For Canny migration mapping
  hmacHash             String                  @default("")
  role                 UserRole                @default(customer)
  segments             String[]                @default([])
  emailVerified        Boolean                 @default(false)
  emailVerifyToken     String?                 @unique
  emailVerifyExpires   DateTime?
  passwordResetToken   String?                 @unique
  passwordResetExpires DateTime?
  lastLoginAt          DateTime?
  company              Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sessions             Session[]
  votes                Vote[]
  painEvents           PainEvent[]
  comments             Comment[]               @relation("CommentAuthor")
  accessRequests       AccessRequest[]
  notifications        Notification[]
  notificationPref     NotificationPreference?
  savedFilters         SavedFilter[]
  zoomConnection       ZoomConnection?
  slackConnection      SlackConnection?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  // Email unique within company, appUserId unique within company
  @@unique([companyId, email])
  @@unique([companyId, appUserId])
  @@index([companyId])
  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  userAgent    String?
  ipAddress    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Board {
  id              String          @id @default(cuid())
  companyId       String          @default("")
  name            String
  slug            String          @default("")  // URL-safe board name
  isPrivate       Boolean         @default(false)
  visibility      BoardVisibility @default(public)
  allowedSegments String[]        @default([])
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categories      Category[]
  posts           Post[]
  accessRequests  AccessRequest[]
  notifications   Notification[]
  changelog       ChangelogEntry[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Board names unique within company
  @@unique([companyId, name])
  @@unique([companyId, slug])
  @@index([companyId])
}

model Category {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([boardId, name])
}

model Post {
  id                String            @id @default(cuid())
  boardId           String
  categoryId        String
  cannyId           String?           @unique  // For Canny migration deduplication
  title             String
  description       String            @default("")
  status            PostStatus        @default(under_review)
  ownerName         String            @default("Unassigned")
  eta               DateTime?
  tags              String[]          @default([])
  score             Int               @default(0)
  totalAttachedMrr  Float             @default(0)
  implicitVoteCount Int               @default(0)
  explicitVoteCount Int               @default(0)
  statusChangedAt   DateTime?                        // When status last changed (for sorting)
  commentSummary    String?           @db.Text        // AI-generated comment summary cache
  commentSummaryAt  DateTime?                        // When summary was last generated
  embedding         Unsupported("vector(1536)")?
  mergedIntoPostId  String?
  board             Board             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  category          Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  votes             Vote[]
  comments          Comment[]
  changelogEntries  ChangelogEntry[]
  matchedPainEvents PainEvent[]       @relation("MatchedPostPainEvents")
  mergedIntoPost    Post?             @relation("PostMerge", fields: [mergedIntoPostId], references: [id], onDelete: SetNull)
  mergedSourcePosts Post[]            @relation("PostMerge")
  notifications     Notification[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([boardId])
  @@index([categoryId])
  @@index([totalAttachedMrr])
  @@index([mergedIntoPostId])
  @@index([statusChangedAt])
}

model Vote {
  id            String      @id @default(cuid())
  userId        String
  postId        String
  voteType      VoteType
  priority      String      @default("none") // none, low, medium, high, critical
  link          String?     // External link (CRM profile, etc.)
  aiActionLogId String?
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  post          Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  aiActionLog   AiActionLog? @relation(fields: [aiActionLogId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, postId])
  @@index([postId, voteType])
}

model PainEvent {
  id                String          @id @default(cuid())
  userId            String
  source            PainEventSource
  sourceReferenceId String
  rawText           String          @db.Text
  status            PainEventStatus @default(pending_ai)
  matchedPostId     String?
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchedPost       Post?           @relation("MatchedPostPainEvents", fields: [matchedPostId], references: [id], onDelete: SetNull)
  aiActionLog       AiActionLog?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([source, sourceReferenceId])
  @@index([status])
  @@index([matchedPostId])
}

model AiActionLog {
  id              String        @id @default(cuid())
  painEventId     String        @unique
  actionTaken     AiActionTaken
  confidenceScore Float
  status          AiActionStatus
  metadata        Json?
  painEvent       PainEvent     @relation(fields: [painEventId], references: [id], onDelete: Cascade)
  votes           Vote[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Comment {
  id               String    @id @default(cuid())
  postId           String
  authorId         String
  value            String    @db.Text
  isPrivate        Boolean   @default(false)
  isPinned         Boolean   @default(false)
  likeCount        Int       @default(0)
  likedByUserIds   String[]  @default([])
  reactions        Json?                       // { "👍": ["userId1"], "🔥": ["userId2"] }
  replyToCommentId String?
  images           String[]  @default([])
  editedAt         DateTime?                   // When comment was last edited
  post             Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author           User      @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  replyToComment   Comment?  @relation("CommentReplies", fields: [replyToCommentId], references: [id], onDelete: SetNull)
  replies          Comment[] @relation("CommentReplies")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([replyToCommentId])
}

model ChangelogEntry {
  id          String   @id @default(cuid())
  postId      String?
  boardId     String?
  title       String
  content     String   @db.Text
  tags        String[] @default([])
  type        String   @default("update") // new, improved, fixed, update
  labels      String[] @default([])       // Product area labels
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  board       Board?   @relation(fields: [boardId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([postId])
  @@index([boardId])
  @@index([isPublished])
}

// ============================================
// TENANT-SCOPED: API Credentials
// ============================================
model ApiCredential {
  id        String   @id @default(cuid())
  companyId String   @default("")
  name      String
  keyHash   String   @unique
  isActive  Boolean  @default(true)
  scopes    Json?
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model AccessRequest {
  id        String              @id @default(cuid())
  userId    String
  boardId   String
  reason    String
  status    AccessRequestStatus @default(pending)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  board     Board               @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([userId, boardId])
  @@index([status])
}

model NotificationPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  productUpdates Boolean  @default(true)
  commentReplies Boolean  @default(true)
  mentions       Boolean  @default(true)
  weeklyDigest   Boolean  @default(true)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  boardId   String
  postId    String?
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  board     Board            @relation(fields: [boardId], references: [id], onDelete: Cascade)
  post      Post?            @relation(fields: [postId], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, createdAt])
  @@index([readAt])
}

model SavedFilter {
  id        String   @id @default(cuid())
  userId    String
  name      String
  criteria  Json
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

// ============================================
// TENANT-SCOPED: AI Inbox Configuration
// ============================================
model AiInboxConfig {
  id                        String             @id @default(cuid())
  companyId                 String             @default("")
  source                    PainEventSource
  routingMode               AiInboxRoutingMode
  triageMode                AiTriageMode       @default(manual)   // auto = AI acts, manual = PM reviews
  spamDetectionEnabled      Boolean            @default(true)     // Filter spam/noise automatically
  enabled                   Boolean            @default(true)
  similarityThreshold       Float              @default(0.75)
  freshdeskDomain           String?
  freshdeskApiKey           String?            @db.Text
  freshdeskFilterField      String?
  freshdeskFilterValue      String?
  freshdeskFieldCatalog     Json?
  freshdeskLastFieldSyncAt  DateTime?
  freshdeskLastTicketSyncAt DateTime?
  slackTeamId               String?
  slackTeamName             String?
  slackChannelIds           String[]           @default([])
  slackChannelNames         String[]           @default([])
  slackLastSyncAt           DateTime?
  company                   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  // One config per source per company
  @@unique([companyId, source])
  @@index([companyId])
}

model ZoomConnection {
  id             String   @id @default(cuid())
  userId         String   @unique
  zoomUserId     String
  zoomAccountId  String?
  zoomUserEmail  String?
  accessToken    String   @db.Text
  refreshToken   String   @db.Text
  tokenType      String   @default("bearer")
  scope          String?
  expiresAt      DateTime?
  connectedAt    DateTime @default(now())
  lastSyncedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([zoomUserId])
}

model SlackConnection {
  id               String   @id @default(cuid())
  userId           String   @unique
  slackTeamId      String
  slackTeamName    String?
  slackUserId      String
  slackUserName    String?
  accessToken      String   @db.Text
  botUserId        String?
  scope            String?
  channelIds       String[] @default([])
  channelNames     String[] @default([])
  connectedAt      DateTime @default(now())
  lastSyncedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([slackTeamId])
}

enum CustomDomainStatus {
  pending_verification
  verified
  failed
  active
}

// ============================================
// TENANT-SCOPED: Custom Domains
// ============================================
model CustomDomain {
  id                 String             @id @default(cuid())
  companyId          String             @default("")
  domain             String             @unique
  status             CustomDomainStatus @default(pending_verification)
  verificationToken  String             @unique @default(cuid())
  verificationMethod String             @default("dns_txt")
  sslStatus          String             @default("pending")
  verifiedAt         DateTime?
  lastCheckedAt      DateTime?
  errorMessage       String?
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([companyId])
  @@index([status])
}

// ============================================
// TENANT-SCOPED: Portal Settings
// ============================================
model PortalSettings {
  id                  String   @id @default(cuid())
  companyId           String   @unique @default("")
  portalName          String   @default("Feedback Portal")
  portalLogo          String?
  primaryColor        String   @default("#004549")
  accentColor         String   @default("#00eef9")
  customCss           String?  @db.Text
  customDomainId      String?  @unique
  allowPublicSignup   Boolean  @default(true)
  requireEmailVerify  Boolean  @default(false)
  maxImageSizeMb      Int      @default(5)
  allowedImageTypes   String[] @default(["image/jpeg", "image/png", "image/gif", "image/webp"])
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ============================================
// ClickUp Integration
// ============================================
model ClickUpConnection {
  id               String   @id @default(cuid())
  companyId        String
  accessToken      String   @db.Text
  teamId           String?
  teamName         String?
  spaceIds         String[] @default([])
  spaceNames       String[] @default([])
  defaultListId    String?
  defaultListName  String?
  webhookId        String?
  syncEnabled      Boolean  @default(true)
  lastSyncedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([companyId])
  @@index([companyId])
}

model ClickUpTaskLink {
  id             String   @id @default(cuid())
  postId         String
  clickUpTaskId  String   @unique
  clickUpUrl     String
  clickUpStatus  String   @default("Open")
  lastSyncedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([postId])
  @@index([clickUpTaskId])
}

model UploadedFile {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  sizeBytes   Int
  url         String
  uploadedBy  String?
  purpose     String   @default("comment")
  createdAt   DateTime @default(now())

  @@index([uploadedBy])
  @@index([purpose])
}
