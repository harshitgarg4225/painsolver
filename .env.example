NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/painsolver
REDIS_URL=redis://localhost:6379
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=changelog-media
OPENAI_API_KEY=mock-openai-key
STRIPE_API_KEY=mock-stripe-key
PAINSOLVER_CLIENT_SECRET=replace_me
PAINSOLVER_MASTER_API_KEY=replace_with_strong_server_key
ALLOW_INSECURE_ACTOR_HEADERS=true
AGENT_REQUIRE_IDEMPOTENCY=true
AGENT_IDEMPOTENCY_TTL_SECONDS=86400
USE_MOCK_FRESHDESK=true
ZOOM_CLIENT_ID=mock-zoom-client-id
ZOOM_CLIENT_SECRET=mock-zoom-client-secret
ZOOM_REDIRECT_URI=http://localhost:3000/api/integrations/zoom/callback
USE_MOCK_ZOOM=true
DEMO_MODE=false
