{
  "name": "painsolver",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native VoC and roadmap platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && prisma db push --skip-generate --accept-data-loss && tsc -p tsconfig.json",
    "postbuild": "node dist/scripts/ensureDefaultCompany.js || true",
    "start": "node dist/server.js",
    "worker": "tsx src/workers/startWorker.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@vercel/blob": "^2.3.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.40.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "openai": "^4.86.1",
    "stripe": "^17.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.8",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
